<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Raj Hotel & Restaurants | NH-19 Aung, Fatehpur | Best Highway Dining</title>
<meta name="description" content="Raj Hotel & Restaurants on NH-19 Aung, Fatehpur. Enjoy Indian, Chinese & South Indian food. Family dining, highway stop. Open 8AM–11:30PM. Order on WhatsApp!">
<meta name="keywords" content="Raj Hotel Fatehpur, highway restaurant NH-19, restaurant Aung Fatehpur, Indian Chinese food highway, family restaurant UP">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;900&family=DM+Sans:wght@300;400;500;600&family=Noto+Serif+Devanagari:wght@600&display=swap" rel="stylesheet">

<style>
:root {
  --gold: #C9A84C;
  --gold-light: #E8C97A;
  --gold-dark: #9A6F20;
  --brown-deep: #1A0F05;
  --brown-dark: #2D1A08;
  --brown-mid: #4A2C10;
  --brown-light: #7A4A20;
  --cream: #F5EDD8;
  --cream-dark: #E8D9BC;
  --white: #FDFAF4;
  --text-muted: #A08060;
  --green-wa: #25D366;
  --red-call: #E53E3E;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; font-size: 16px; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--brown-deep);
  color: var(--cream);
  overflow-x: hidden;
}

/* ===================== NAVBAR ===================== */
#navbar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
  padding: 0 5%;
  display: flex; align-items: center; justify-content: space-between;
  height: 70px;
  transition: all 0.4s ease;
  background: transparent;
}
#navbar.scrolled {
  background: rgba(26, 15, 5, 0.97);
  border-bottom: 1px solid rgba(201, 168, 76, 0.2);
  backdrop-filter: blur(12px);
  box-shadow: 0 4px 30px rgba(0,0,0,0.5);
}
.nav-logo {
  font-family: 'Playfair Display', serif;
  font-size: 1.4rem; font-weight: 700;
  color: var(--gold);
  letter-spacing: 0.02em;
  text-decoration: none;
  display: flex; align-items: center; gap: 8px;
}
.nav-logo span { font-size: 1.6rem; }
.nav-links {
  display: flex; gap: 2rem; list-style: none; align-items: center;
}
.nav-links a {
  color: var(--cream); text-decoration: none;
  font-size: 0.9rem; font-weight: 500;
  letter-spacing: 0.05em; text-transform: uppercase;
  transition: color 0.3s;
}
.nav-links a:hover { color: var(--gold); }
.nav-cta {
  background: var(--green-wa);
  color: #fff !important; padding: 8px 18px;
  border-radius: 25px; font-weight: 600 !important;
  transition: transform 0.2s, box-shadow 0.2s !important;
}
.nav-cta:hover { transform: scale(1.05); box-shadow: 0 4px 20px rgba(37,211,102,0.4) !important; color: #fff !important; }
.hamburger {
  display: none; flex-direction: column; gap: 5px;
  cursor: pointer; padding: 5px;
}
.hamburger span {
  display: block; width: 25px; height: 2px;
  background: var(--gold); border-radius: 2px;
  transition: all 0.3s;
}
.mobile-menu {
  display: none; position: fixed; top: 70px; left: 0; right: 0;
  background: rgba(26, 15, 5, 0.98);
  padding: 1.5rem 5%; z-index: 999;
  border-bottom: 1px solid rgba(201, 168, 76, 0.2);
}
.mobile-menu.open { display: flex; flex-direction: column; gap: 1rem; }
.mobile-menu a {
  color: var(--cream); text-decoration: none;
  font-size: 1rem; font-weight: 500; padding: 0.5rem 0;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

/* ===================== HERO ===================== */
#hero {
  min-height: 100vh; position: relative;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
}
.hero-bg {
  position: absolute; inset: 0;
  background: 
    linear-gradient(to bottom, rgba(26,15,5,0.65) 0%, rgba(26,15,5,0.45) 40%, rgba(26,15,5,0.85) 100%),
    url('https://images.unsplash.com/photo-1567188040759-fb8a883dc6d8?w=1600&q=80') center/cover no-repeat;
  transform-origin: center;
  animation: heroZoom 18s ease-in-out infinite alternate;
}
@keyframes heroZoom {
  from { transform: scale(1); }
  to { transform: scale(1.08); }
}
.hero-badge {
  display: inline-flex; align-items: center; gap: 6px;
  background: rgba(201, 168, 76, 0.15);
  border: 1px solid rgba(201, 168, 76, 0.4);
  padding: 6px 16px; border-radius: 20px;
  font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--gold-light); margin-bottom: 1.2rem;
  animation: fadeInDown 0.8s ease both;
}
.hero-content {
  position: relative; z-index: 2;
  text-align: center; padding: 0 5%;
  max-width: 900px;
}
.hero-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2.8rem, 7vw, 6rem);
  font-weight: 900; line-height: 1.05;
  color: var(--white);
  text-shadow: 0 4px 30px rgba(0,0,0,0.5);
  animation: fadeInUp 1s ease 0.2s both;
}
.hero-title span { color: var(--gold); }
.hero-sub {
  font-size: clamp(1rem, 2.5vw, 1.3rem);
  color: var(--cream-dark); margin: 1rem 0 2.2rem;
  letter-spacing: 0.08em; font-weight: 300;
  animation: fadeInUp 1s ease 0.4s both;
}
.hero-sub .dot { color: var(--gold); margin: 0 0.5rem; }
.hero-info {
  display: flex; justify-content: center; gap: 1.5rem;
  margin-bottom: 2rem; flex-wrap: wrap;
  animation: fadeInUp 1s ease 0.5s both;
}
.hero-info-item {
  display: flex; align-items: center; gap: 6px;
  font-size: 0.85rem; color: var(--cream-dark);
}
.hero-info-item svg { color: var(--gold); flex-shrink: 0; }
.hero-btns {
  display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;
  animation: fadeInUp 1s ease 0.6s both;
}
.btn-primary {
  display: inline-flex; align-items: center; gap: 8px;
  background: linear-gradient(135deg, var(--gold), var(--gold-dark));
  color: var(--brown-deep); padding: 14px 30px;
  border-radius: 50px; font-weight: 700; font-size: 0.95rem;
  text-decoration: none; transition: all 0.3s;
  box-shadow: 0 6px 25px rgba(201,168,76,0.35);
  letter-spacing: 0.03em;
}
.btn-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 35px rgba(201,168,76,0.5); }
.btn-whatsapp {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--green-wa);
  color: #fff; padding: 14px 30px;
  border-radius: 50px; font-weight: 700; font-size: 0.95rem;
  text-decoration: none; transition: all 0.3s;
  box-shadow: 0 6px 25px rgba(37,211,102,0.35);
}
.btn-whatsapp:hover { transform: translateY(-2px); box-shadow: 0 10px 35px rgba(37,211,102,0.5); background: #1eb857; }
.scroll-arrow {
  position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%);
  z-index: 2; display: flex; flex-direction: column; align-items: center; gap: 4px;
  color: var(--gold); font-size: 0.7rem; letter-spacing: 0.15em;
  text-transform: uppercase; animation: bounce 2s ease-in-out infinite;
  text-decoration: none;
}
.scroll-arrow svg { animation: arrowBounce 2s ease-in-out infinite; }
@keyframes arrowBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(6px); }
}
@keyframes bounce {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}

/* ===================== SECTION COMMONS ===================== */
section { padding: 80px 5%; }
.section-label {
  font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase;
  color: var(--gold); font-weight: 600; margin-bottom: 0.5rem;
  display: flex; align-items: center; gap: 10px;
}
.section-label::before, .section-label::after {
  content: ''; flex: 1; height: 1px; background: rgba(201,168,76,0.3);
  max-width: 50px;
}
.section-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 700; color: var(--white);
  line-height: 1.2; margin-bottom: 0.5rem;
}
.section-title span { color: var(--gold); }
.section-desc {
  color: var(--text-muted); font-size: 1rem; font-weight: 300;
  max-width: 500px; line-height: 1.6; margin-bottom: 3rem;
}
.section-header { text-align: center; margin-bottom: 3rem; }
.section-header .section-label { justify-content: center; }
.section-header .section-desc { margin: 0 auto 0; }

/* ===================== POPULAR DISHES ===================== */
#popular { background: var(--brown-dark); }
.dishes-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1.5rem;
}
.dish-card {
  background: var(--brown-mid);
  border-radius: 16px; overflow: hidden;
  border: 1px solid rgba(201,168,76,0.1);
  transition: all 0.4s ease;
  position: relative;
}
.dish-card:hover {
  transform: translateY(-6px);
  border-color: rgba(201,168,76,0.35);
  box-shadow: 0 20px 50px rgba(0,0,0,0.4);
}
.dish-img {
  width: 100%; height: 200px; object-fit: cover;
  display: block; transition: transform 0.5s ease;
}
.dish-card:hover .dish-img { transform: scale(1.05); }
.dish-info { padding: 1.2rem 1.3rem 1.5rem; }
.dish-name {
  font-family: 'Playfair Display', serif;
  font-size: 1.2rem; font-weight: 600; color: var(--white);
  margin-bottom: 0.4rem;
}
.dish-desc { font-size: 0.85rem; color: var(--text-muted); line-height: 1.5; }
.dish-tag {
  position: absolute; top: 12px; left: 12px;
  background: var(--gold); color: var(--brown-deep);
  font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em;
  text-transform: uppercase; padding: 3px 10px; border-radius: 20px;
}
.order-dish-btn {
  display: flex; align-items: center; gap: 6px;
  margin-top: 1rem; background: rgba(37,211,102,0.1);
  border: 1px solid rgba(37,211,102,0.3);
  color: #25D366; padding: 8px 14px; border-radius: 25px;
  font-size: 0.82rem; font-weight: 600; text-decoration: none;
  transition: all 0.3s; width: fit-content;
}
.order-dish-btn:hover { background: var(--green-wa); color: #fff; border-color: var(--green-wa); }

/* ===================== MENU ===================== */
#menu { background: var(--brown-deep); }
.menu-tabs {
  display: flex; gap: 0.6rem; flex-wrap: wrap;
  justify-content: center; margin-bottom: 2.5rem;
}
.menu-tab {
  padding: 8px 20px; border-radius: 25px; cursor: pointer;
  font-size: 0.85rem; font-weight: 600; letter-spacing: 0.04em;
  background: transparent;
  border: 1px solid rgba(201,168,76,0.25);
  color: var(--text-muted); transition: all 0.3s;
}
.menu-tab.active, .menu-tab:hover {
  background: var(--gold); color: var(--brown-deep);
  border-color: var(--gold);
}
.menu-category { display: none; }
.menu-category.active { display: block; }
.menu-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 1rem;
}
.menu-item {
  background: var(--brown-dark);
  border: 1px solid rgba(201,168,76,0.08);
  border-radius: 12px; padding: 1rem 1.2rem;
  display: flex; align-items: center; justify-content: space-between;
  transition: all 0.3s;
}
.menu-item:hover {
  border-color: rgba(201,168,76,0.3);
  background: var(--brown-mid);
  transform: translateX(4px);
}
.menu-item-name {
  font-size: 0.95rem; font-weight: 500; color: var(--white);
}
.menu-veg-icon {
  width: 16px; height: 16px; border: 1.5px solid #4CAF50;
  border-radius: 3px; display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.menu-veg-icon::after {
  content: ''; width: 8px; height: 8px;
  background: #4CAF50; border-radius: 50%;
}
.menu-cta-banner {
  margin-top: 2.5rem;
  background: linear-gradient(135deg, rgba(201,168,76,0.1), rgba(201,168,76,0.05));
  border: 1px solid rgba(201,168,76,0.2);
  border-radius: 16px; padding: 2rem;
  text-align: center;
}
.menu-cta-banner h3 {
  font-family: 'Playfair Display', serif;
  font-size: 1.5rem; color: var(--white); margin-bottom: 0.5rem;
}
.menu-cta-banner p { color: var(--text-muted); margin-bottom: 1.2rem; }

/* ===================== SIZZLERS ===================== */
#sizzlers { background: var(--brown-dark); }
.sizzlers-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 2rem;
}
.sizzler-card {
  background: linear-gradient(145deg, var(--brown-mid), var(--brown-dark));
  border: 1px solid rgba(201,168,76,0.25);
  border-radius: 20px; padding: 2.5rem 2rem;
  text-align: center; position: relative; overflow: hidden;
  transition: all 0.4s;
}
.sizzler-card::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(ellipse at top center, rgba(201,168,76,0.08), transparent 70%);
}
.sizzler-card:hover {
  transform: translateY(-8px);
  border-color: rgba(201,168,76,0.5);
  box-shadow: 0 25px 60px rgba(0,0,0,0.5), inset 0 0 40px rgba(201,168,76,0.04);
}
.sizzler-icon {
  font-size: 4rem; margin-bottom: 0.5rem;
  display: block;
  filter: drop-shadow(0 0 15px rgba(255, 180, 50, 0.5));
}
.steam {
  position: relative; display: inline-block;
}
.steam::before, .steam::after {
  content: '〜';
  position: absolute; top: -20px; font-size: 1.4rem;
  color: rgba(255,255,255,0.25);
  animation: steamRise 2s ease-in-out infinite;
}
.steam::before { left: 20%; animation-delay: 0s; }
.steam::after { right: 20%; animation-delay: 0.7s; }
@keyframes steamRise {
  0% { opacity: 0; transform: translateY(0) scaleX(1); }
  50% { opacity: 0.6; transform: translateY(-15px) scaleX(1.2); }
  100% { opacity: 0; transform: translateY(-30px) scaleX(0.8); }
}
.sizzler-name {
  font-family: 'Playfair Display', serif;
  font-size: 1.5rem; font-weight: 700; color: var(--white);
  margin-bottom: 0.5rem; position: relative;
}
.sizzler-desc { font-size: 0.88rem; color: var(--text-muted); margin-bottom: 1.2rem; line-height: 1.5; position: relative; }
.sizzler-price {
  font-size: 2rem; font-weight: 700;
  color: var(--gold); font-family: 'Playfair Display', serif;
  position: relative;
}
.sizzler-badge {
  position: absolute; top: -1px; right: -1px;
  background: var(--gold); color: var(--brown-deep);
  font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em;
  padding: 6px 14px; border-radius: 0 20px 0 12px;
  text-transform: uppercase;
}

/* ===================== GALLERY ===================== */
#gallery { background: var(--brown-deep); }
.masonry-grid {
  columns: 3; column-gap: 1rem;
}
.masonry-item {
  break-inside: avoid; margin-bottom: 1rem;
  border-radius: 12px; overflow: hidden;
  position: relative;
}
.masonry-item img {
  width: 100%; display: block; transition: transform 0.5s ease;
}
.masonry-item:hover img { transform: scale(1.04); }
.masonry-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(26,15,5,0.7), transparent);
  opacity: 0; transition: opacity 0.3s;
  display: flex; align-items: flex-end; padding: 1rem;
}
.masonry-item:hover .masonry-overlay { opacity: 1; }
.masonry-overlay span {
  color: var(--cream); font-size: 0.85rem; font-weight: 500;
}

/* ===================== REVIEWS ===================== */
#reviews { background: var(--brown-dark); }
.reviews-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1.5rem;
}
.review-card {
  background: var(--brown-mid);
  border: 1px solid rgba(201,168,76,0.1);
  border-radius: 16px; padding: 1.8rem;
  transition: all 0.3s; position: relative;
}
.review-card::before {
  content: '"'; position: absolute; top: 10px; right: 20px;
  font-family: 'Playfair Display', serif; font-size: 5rem;
  color: rgba(201,168,76,0.1); line-height: 1;
}
.review-card:hover {
  transform: translateY(-4px);
  border-color: rgba(201,168,76,0.25);
  box-shadow: 0 15px 40px rgba(0,0,0,0.3);
}
.stars { color: var(--gold); font-size: 1.1rem; margin-bottom: 0.8rem; letter-spacing: 2px; }
.review-text {
  font-size: 0.95rem; color: var(--cream-dark);
  line-height: 1.7; font-style: italic; margin-bottom: 1.2rem;
}
.reviewer {
  display: flex; align-items: center; gap: 10px;
}
.reviewer-avatar {
  width: 40px; height: 40px; border-radius: 50%;
  background: linear-gradient(135deg, var(--gold-dark), var(--brown-mid));
  display: flex; align-items: center; justify-content: center;
  font-weight: 700; color: var(--gold-light); font-size: 1rem;
  flex-shrink: 0;
}
.reviewer-name { font-weight: 600; color: var(--white); font-size: 0.9rem; }
.reviewer-meta { font-size: 0.78rem; color: var(--text-muted); }

/* ===================== LOCATION ===================== */
#location { background: var(--brown-deep); }
.location-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start;
}
.map-container {
  border-radius: 16px; overflow: hidden;
  border: 1px solid rgba(201,168,76,0.2);
  box-shadow: 0 20px 60px rgba(0,0,0,0.4);
}
.map-container iframe { display: block; width: 100%; height: 400px; }
.location-info h2 {
  font-family: 'Playfair Display', serif;
  font-size: 2rem; color: var(--white); margin-bottom: 1.5rem;
}
.loc-item {
  display: flex; gap: 1rem; align-items: flex-start;
  margin-bottom: 1.5rem; padding-bottom: 1.5rem;
  border-bottom: 1px solid rgba(201,168,76,0.1);
}
.loc-icon {
  width: 44px; height: 44px; border-radius: 10px;
  background: rgba(201,168,76,0.1); border: 1px solid rgba(201,168,76,0.2);
  display: flex; align-items: center; justify-content: center;
  color: var(--gold); flex-shrink: 0; font-size: 1.2rem;
}
.loc-text h4 { color: var(--white); font-weight: 600; margin-bottom: 0.3rem; }
.loc-text p, .loc-text a {
  color: var(--text-muted); font-size: 0.9rem; line-height: 1.5;
  text-decoration: none;
}
.loc-text a:hover { color: var(--gold); }
.location-btns { display: flex; flex-direction: column; gap: 0.8rem; margin-top: 2rem; }
.btn-outline-gold {
  display: inline-flex; align-items: center; justify-content: center; gap: 8px;
  border: 1.5px solid var(--gold); color: var(--gold);
  padding: 12px 24px; border-radius: 50px; font-weight: 600;
  font-size: 0.9rem; text-decoration: none; transition: all 0.3s;
}
.btn-outline-gold:hover { background: var(--gold); color: var(--brown-deep); }
.btn-call {
  display: inline-flex; align-items: center; justify-content: center; gap: 8px;
  background: rgba(229,62,62,0.1); border: 1.5px solid rgba(229,62,62,0.4);
  color: #FC8181; padding: 12px 24px; border-radius: 50px;
  font-weight: 600; font-size: 0.9rem; text-decoration: none; transition: all 0.3s;
}
.btn-call:hover { background: var(--red-call); color: #fff; border-color: var(--red-call); }

/* ===================== CONVERSION BANNER ===================== */
#cta-banner {
  background: linear-gradient(135deg, var(--brown-mid) 0%, #3d1f08 50%, var(--brown-mid) 100%);
  border-top: 1px solid rgba(201,168,76,0.2);
  border-bottom: 1px solid rgba(201,168,76,0.2);
  text-align: center; padding: 80px 5%;
  position: relative; overflow: hidden;
}
#cta-banner::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(ellipse at center, rgba(201,168,76,0.08), transparent 70%);
}
#cta-banner h2 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(1.8rem, 4vw, 3.2rem);
  color: var(--white); margin-bottom: 0.8rem;
  position: relative;
}
#cta-banner h2 span { color: var(--gold); }
#cta-banner p { color: var(--text-muted); margin-bottom: 2.5rem; font-size: 1.05rem; position: relative; }
.cta-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; position: relative; }
.btn-cta-call {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(229,62,62,0.1); border: 2px solid rgba(229,62,62,0.4);
  color: #FC8181; padding: 14px 30px; border-radius: 50px;
  font-weight: 700; font-size: 0.95rem; text-decoration: none; transition: all 0.3s;
}
.btn-cta-call:hover { background: var(--red-call); color: #fff; border-color: var(--red-call); transform: translateY(-2px); }

/* ===================== FOOTER ===================== */
footer {
  background: #120A02;
  border-top: 1px solid rgba(201,168,76,0.15);
  padding: 60px 5% 30px;
}
.footer-grid {
  display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 3rem;
  margin-bottom: 3rem;
}
.footer-brand h3 {
  font-family: 'Playfair Display', serif;
  font-size: 1.6rem; color: var(--gold); margin-bottom: 0.8rem;
}
.footer-brand p { color: var(--text-muted); font-size: 0.9rem; line-height: 1.7; max-width: 280px; }
.footer-col h4 {
  color: var(--white); font-size: 0.85rem;
