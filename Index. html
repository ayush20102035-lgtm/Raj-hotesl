.footer-bottom p { color: var(--text-muted); font-size: 0.82rem; }
.footer-bottom a { color: var(--gold); text-decoration: none; }

/* ===================== FLOATING BUTTONS ===================== */
.floating-btns {
  position: fixed; bottom: 1.5rem; right: 1.5rem;
